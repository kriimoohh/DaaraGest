# ── Base de données (fournie automatiquement par Railway PostgreSQL) ───────────
DATABASE_URL=postgresql://user:password@host:5432/daaragest

# ── Authentification JWT (obligatoire — le serveur refuse de démarrer sans) ───
JWT_SECRET=changez-cette-valeur-en-production-minimum-32-caracteres
JWT_EXPIRES_IN=24h

# ── Signature QR codes (obligatoire — le serveur refuse de démarrer sans) ─────
# Utilisé pour signer les QR codes des cartes élèves/professeurs (HMAC SHA-256)
# Si oublié, un attaquant pourrait forger des QR valides → bypass du pointage
QR_SECRET=changez-cette-valeur-en-production-minimum-32-caracteres

# ── CORS (URL du frontend en production — plusieurs valeurs séparées par des virgules) ──
# Exemple : CORS_ORIGIN=https://dg.sakai.sn
# Exemple multi : CORS_ORIGIN=https://dg.sakai.sn,https://www.dg.sakai.sn
CORS_ORIGIN=https://votre-frontend.up.railway.app

# ── Cookies (domaine partagé entre frontend et API en production) ─────────────
# Doit correspondre au domaine sur lequel l'app est déployée.
# Exemple : COOKIE_DOMAIN=.exemple.com pour partager entre app.exemple.com et api.exemple.com
# Laisser vide pour ne pas définir de domain (cookie scopé au host de la requête).
COOKIE_DOMAIN=

# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
