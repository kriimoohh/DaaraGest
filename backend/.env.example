# ── Base de données (fournie automatiquement par Railway PostgreSQL) ───────────
DATABASE_URL=postgresql://user:password@host:5432/daaragest

# ── Authentification JWT (obligatoire — le serveur refuse de démarrer sans) ───
JWT_SECRET=changez-cette-valeur-en-production-minimum-32-caracteres
JWT_EXPIRES_IN=24h

# ── CORS (URL du frontend en production — plusieurs valeurs séparées par des virgules) ──
# Exemple : CORS_ORIGIN=https://dg.sakai.sn
# Exemple multi : CORS_ORIGIN=https://dg.sakai.sn,https://www.dg.sakai.sn
CORS_ORIGIN=https://votre-frontend.up.railway.app

# ── Cookies (domaine partagé entre frontend et API en production) ─────────────
# Permet le partage des cookies entre dg.sakai.sn et api.dg.sakai.sn
# Laisser vide pour utiliser la valeur par défaut (.dg.sakai.sn)
COOKIE_DOMAIN=.dg.sakai.sn

# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
