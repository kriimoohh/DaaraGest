# ── Base de données (fournie automatiquement par Railway PostgreSQL) ───────────
DATABASE_URL=postgresql://user:password@host:5432/daaragest

# ── Authentification JWT (obligatoire — le serveur refuse de démarrer sans) ───
JWT_SECRET=changez-cette-valeur-en-production-minimum-32-caracteres
JWT_EXPIRES_IN=7d

# ── CORS (mettre l'URL Railway du frontend en production) ─────────────────────
CORS_ORIGIN=https://votre-frontend.up.railway.app

# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
