{
  "name": "daaragest-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "prisma migrate deploy && node prisma/seed-prod.cjs && node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:cleanup": "tsx prisma/cleanup.ts",
    "db:migrate-matieres": "tsx prisma/migrate-matieres-lgm.ts",
    "db:migrate-matieres:apply": "tsx prisma/migrate-matieres-lgm.ts --apply",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.43.0",
    "qrcode": "^1.5.4",
    "zod": "^3.22.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "prisma": "^5.22.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
