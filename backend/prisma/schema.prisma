generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Etablissement {
  id          String   @id @default(uuid())
  nom_fr      String
  adresse     String?
  telephone   String?
  logo_url      String?
  signature_url String?
  cachet_url    String?
  nom_directeur String?
  devise        String   @default("FCFA")
  actif       Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  utilisateurs            Utilisateur[]
  annees_scolaires        AnneeScolaire[]
  classes                 Classe[]
  eleves                  Eleve[]
  matieres                Matiere[]
  niveaux                 Niveau[]
  config_notes            ConfigNotes?
  absences_eleves         AbsenceEleve[]
  creneaux                Creneau[]
  evenements_calendrier   EvenementCalendrier[]
  notifications           Notification[]
  conversations           Conversation[]
  portail_tokens          PortailParentToken[]
  evaluations             Evaluation[]
  progressions_eleves     ProgressionEleve[]
  activites               Activite[]
  document_templates      DocumentTemplate[]
  documents_generes       DocumentGenere[]
  demandes_absence_prof   DemandeAbsenceProfesseur[]
}

model Role {
  id          String   @id @default(uuid())
  libelle_fr  String   @unique
  permissions Json     @default("{}")
  created_at  DateTime @default(now())

  utilisateurs Utilisateur[]
}

model Utilisateur {
  id                   String    @id @default(uuid())
  etablissement_id     String
  role_id              String
  nom_fr               String
  nom_ar               String
  prenom_fr            String?
  identifiant          String    @unique
  email                String?
  mot_de_passe         String
  langue               String    @default("fr")
  theme                String    @default("light")
  actif                Boolean   @default(true)
  must_change_password Boolean   @default(false)
  last_login           DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  etablissement       Etablissement         @relation(fields: [etablissement_id], references: [id])
  role                Role                  @relation(fields: [role_id], references: [id])
  professeur          Professeur?
  evenements_crees    EvenementCalendrier[]
  notifications_recues Notification[]
  conversations_participees ConversationParticipant[]
  messages_envoyes    MessageConversation[]
  activites_responsable Activite[]          @relation("ActiviteResponsable")
  documents_generes     DocumentGenere[]    @relation("DocumentsGeneres")
  demandes_traitees     DemandeAbsenceProfesseur[] @relation("DemandesTraitees")
  refresh_tokens        RefreshToken[]

  @@index([etablissement_id])
  @@index([etablissement_id, actif])
}

model Professeur {
  id               String    @id @default(uuid())
  utilisateur_id   String    @unique
  specialite_fr    String?
  specialite_ar    String?
  telephone        String?
  date_embauche    DateTime?
  type_contrat     String    @default("permanent")
  salaire_base     Decimal?  @db.Decimal(10, 2)
  photo_url        String?
  qr_token         String?   @unique
  poste_fr         String?
  date_fin_contrat DateTime?
  date_debut_stage DateTime?
  date_fin_stage   DateTime?
  created_at       DateTime  @default(now())

  utilisateur      Utilisateur          @relation(fields: [utilisateur_id], references: [id])
  cartes_nfc       ProfesseurCarte[]
  pointages        Pointage[]
  heures_travail   HeureTravail[]
  presences        PresenceProfesseur[]
  paiements        PaiementProfesseur[]
  matieres_classes ProfMatiereClasse[]
  creneaux         Creneau[]
  demandes_absence DemandeAbsenceProfesseur[]
}

// TODO(NFC): Ces trois modèles sont réservés au futur module de pointage automatique
// par badge NFC (ProfesseurCarte → lecture → Pointage → calcul HeureTravail).
// Aucune API ne les expose actuellement. Voir roadmap.

model ProfesseurCarte {
  id            String   @id @default(uuid())
  professeur_id String
  uid_nfc       String   @unique
  active        Boolean  @default(true)
  created_at    DateTime @default(now())

  professeur Professeur @relation(fields: [professeur_id], references: [id])
}

model Pointage {
  id            String   @id @default(uuid())
  professeur_id String
  type          String
  horodatage    DateTime @default(now())
  uid_carte     String
  valide        Boolean  @default(true)

  professeur Professeur @relation(fields: [professeur_id], references: [id])
}

model HeureTravail {
  id            String    @id @default(uuid())
  professeur_id String
  date_jour     DateTime  @db.Date
  heure_arrivee DateTime?
  heure_depart  DateTime?
  duree_minutes Int?
  created_at    DateTime  @default(now())

  professeur Professeur @relation(fields: [professeur_id], references: [id])
}

model PresenceProfesseur {
  id              String   @id @default(uuid())
  professeur_id   String
  date            DateTime @db.Date
  statut          String   // 'present' | 'absent' | 'retard' | 'conge'
  heure_arrivee   String?  // format HH:MM
  heure_depart    String?  // format HH:MM
  heures_prevues  Decimal? @db.Decimal(4, 2)
  heures_reelles  Decimal? @db.Decimal(4, 2)  // calculé auto si arrivee+depart fournis
  motif           String?
  source          String   @default("manuel")  // 'manuel' | 'qr'
  created_at      DateTime @default(now())

  professeur Professeur @relation(fields: [professeur_id], references: [id])

  @@unique([professeur_id, date])
}

model PaiementProfesseur {
  id                String   @id @default(uuid())
  professeur_id     String
  mois              Int
  annee             Int
  heures_theoriques Decimal? @db.Decimal(6, 2)
  heures_reelles    Decimal? @db.Decimal(6, 2)
  montant_brut      Decimal  @db.Decimal(12, 2)
  retenues          Decimal  @default(0) @db.Decimal(12, 2)
  net_a_payer       Decimal  @db.Decimal(12, 2)
  statut            String   @default("en_attente")
  created_at        DateTime @default(now())

  professeur Professeur @relation(fields: [professeur_id], references: [id])
}

model AnneeScolaire {
  id               String   @id @default(uuid())
  etablissement_id String
  libelle          String
  date_debut       DateTime @db.Date
  date_fin         DateTime @db.Date
  active           Boolean  @default(false)
  created_at       DateTime @default(now())

  etablissement   Etablissement       @relation(fields: [etablissement_id], references: [id])
  classes         Classe[]
  inscriptions    Inscription[]
  prof_matieres   ProfMatiereClasse[]
  bulletins       Bulletin[]
  notes           Note[]
  absences_eleves AbsenceEleve[]
  creneaux        Creneau[]
  evaluations             Evaluation[]
  progressions_eleves     ProgressionEleve[]
  inscriptions_activites  InscriptionActivite[]

  @@index([etablissement_id])
  @@index([etablissement_id, active])
}

model ConfigNotes {
  id               String   @id @default(uuid())
  etablissement_id String   @unique
  note_max         Decimal  @default(20) @db.Decimal(5, 2)
  note_min         Decimal  @default(0) @db.Decimal(5, 2)
  nb_periodes      Int      @default(3)
  noms_periodes    Json     @default("{\"fr\":[\"1er Trimestre\",\"2ème Trimestre\",\"3ème Trimestre\"],\"ar\":[\"الفصل الأول\",\"الفصل الثاني\",\"الفصل الثالث\"]}")
  arrondi                 Int      @default(2)
  chiffres_arabes         Boolean  @default(false)
  montant_mensualite      Decimal  @default(7500) @db.Decimal(10, 2)
  seuil_absences_alerte   Int      @default(3)
  seuil_note_insuffisante Decimal  @default(10) @db.Decimal(5, 2)
  jours_cours             Json     @default("[\"lundi\",\"mardi\",\"mercredi\",\"jeudi\",\"vendredi\"]")
  notif_paiement_retard   Boolean  @default(true)
  notif_absences_eleves   Boolean  @default(true)
  notif_messages          Boolean  @default(true)
  notif_inscriptions      Boolean  @default(false)
  updated_at              DateTime @updatedAt

  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])
}

model Matiere {
  id               String  @id @default(uuid())
  etablissement_id String
  nom_fr           String
  nom_ar           String
  filiere          String
  coeff_defaut     Decimal @default(1)  @db.Decimal(4, 2)
  note_max         Decimal @default(20) @db.Decimal(5, 2)
  note_min         Decimal @default(0)  @db.Decimal(5, 2)
  ordre_bulletin   Int     @default(0)
  active           Boolean @default(true)

  etablissement   Etablissement       @relation(fields: [etablissement_id], references: [id])
  prof_matieres   ProfMatiereClasse[]
  notes           Note[]
  classe_matieres ClasseMatiere[]
  creneaux        Creneau[]
  evaluations     Evaluation[]

  @@index([etablissement_id])
  @@index([etablissement_id, active])
}

model Niveau {
  id               String  @id @default(uuid())
  etablissement_id String
  libelle          String
  ordre            Int     @default(0)

  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])
  classes       Classe[]

  @@unique([etablissement_id, libelle])
}

model Classe {
  id               String  @id @default(uuid())
  etablissement_id String
  annee_scolaire_id String
  nom_fr           String
  filiere          String
  niveau_id        String?
  capacite         Int     @default(30)
  active           Boolean @default(true)

  etablissement  Etablissement       @relation(fields: [etablissement_id], references: [id])
  annee_scolaire AnneeScolaire       @relation(fields: [annee_scolaire_id], references: [id])
  niveau         Niveau?             @relation(fields: [niveau_id], references: [id])
  inscriptions_fr Inscription[]      @relation("ClasseFR")
  inscriptions_ar Inscription[]      @relation("ClasseAR")
  prof_matieres   ProfMatiereClasse[]
  absences        AbsenceEleve[]
  classe_matieres ClasseMatiere[]
  creneaux        Creneau[]
  evaluations     Evaluation[]

  @@index([etablissement_id])
  @@index([etablissement_id, annee_scolaire_id])
}

model ClasseMatiere {
  id             String   @id @default(uuid())
  classe_id      String
  matiere_id     String
  coeff_override Decimal? @db.Decimal(4, 2)
  ordre_override Int?

  classe  Classe  @relation(fields: [classe_id], references: [id])
  matiere Matiere @relation(fields: [matiere_id], references: [id])

  @@unique([classe_id, matiere_id])
}

model ProfMatiereClasse {
  id                String  @id @default(uuid())
  professeur_id     String
  classe_id         String
  matiere_id        String
  annee_scolaire_id String

  professeur     Professeur    @relation(fields: [professeur_id], references: [id])
  classe         Classe        @relation(fields: [classe_id], references: [id])
  matiere        Matiere       @relation(fields: [matiere_id], references: [id])
  annee_scolaire AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])
}

model Eleve {
  id               String   @id @default(uuid())
  etablissement_id String
  matricule        String   @unique
  nom_fr           String
  prenom_fr        String
  date_naissance   DateTime @db.Date
  lieu_naissance   String?
  sexe             String
  photo_url        String?
  qr_token         String?  @unique
  actif            Boolean  @default(true)
  created_at       DateTime @default(now())

  etablissement Etablissement   @relation(fields: [etablissement_id], references: [id])
  parents       Parent[]
  inscriptions  Inscription[]
  paiements     PaiementEleve[]
  bulletins     Bulletin[]
  notes         Note[]
  absences      AbsenceEleve[]
  portail_tokens PortailParentToken[]
  notes_evaluations      NoteEvaluation[]
  progressions           ProgressionEleve[]
  inscriptions_activites InscriptionActivite[]
  presences_activites    PresenceActivite[]
  emprunts               Emprunt[]

  @@index([etablissement_id])
  @@index([etablissement_id, actif])
  @@index([etablissement_id, nom_fr])
}

model Parent {
  id        String  @id @default(uuid())
  eleve_id  String
  nom_fr    String
  nom_ar    String?
  lien      String
  telephone String
  email     String?
  adresse   String?

  eleve Eleve @relation(fields: [eleve_id], references: [id])
}

model Inscription {
  id                String   @id @default(uuid())
  eleve_id          String
  classe_fr_id      String?
  classe_ar_id      String?
  annee_scolaire_id String
  date_inscription  DateTime @default(now())
  statut            String   @default("actif")
  created_at        DateTime @default(now())

  eleve          Eleve         @relation(fields: [eleve_id], references: [id])
  classe_fr      Classe?       @relation("ClasseFR", fields: [classe_fr_id], references: [id])
  classe_ar      Classe?       @relation("ClasseAR", fields: [classe_ar_id], references: [id])
  annee_scolaire AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])
  paiements      PaiementEleve[]
}

model PaiementEleve {
  id             String   @id @default(uuid())
  eleve_id       String
  inscription_id String?
  type           String
  montant        Decimal  @db.Decimal(12, 2)
  mois           Int?
  annee          Int?
  statut         String   @default("paye")
  recu_numero    String?
  created_at     DateTime @default(now())

  eleve       Eleve        @relation(fields: [eleve_id], references: [id])
  inscription Inscription? @relation(fields: [inscription_id], references: [id])

  @@index([eleve_id, mois, annee])
  @@index([annee, mois])
}

model Note {
  id                String   @id @default(uuid())
  eleve_id          String
  matiere_id        String
  periode           Int
  annee_scolaire_id String
  valeur            Decimal  @db.Decimal(5, 2)
  commentaire       String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  matiere        Matiere       @relation(fields: [matiere_id], references: [id])
  annee_scolaire AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])
  eleve          Eleve         @relation(fields: [eleve_id], references: [id])

  @@unique([eleve_id, matiere_id, periode, annee_scolaire_id])
}

model AuditLog {
  id               String   @id @default(uuid())
  etablissement_id String
  utilisateur_id   String
  action           String   // 'CREATE' | 'UPDATE' | 'DELETE'
  entite           String   // 'PaiementEleve', 'Eleve', 'Utilisateur', 'Note', ...
  entite_id        String
  details          Json?
  created_at       DateTime @default(now())

  @@index([etablissement_id, created_at])
  @@index([entite, entite_id])
}

model Bulletin {
  id                String    @id @default(uuid())
  eleve_id          String
  annee_scolaire_id String
  filiere           String
  periode           Int
  moyenne           Decimal?  @db.Decimal(5, 2)
  rang              Int?
  appreciation      String?
  observation_fr    String?
  observation_ar    String?
  observation_prof  String?
  valide_par        String?
  valide_le         DateTime?
  pdf_url           String?
  generated_at      DateTime?
  created_at        DateTime  @default(now())

  eleve          Eleve         @relation(fields: [eleve_id], references: [id])
  annee_scolaire AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])

  @@unique([eleve_id, annee_scolaire_id, filiere, periode])
}

model AbsenceEleve {
  id                String        @id @default(uuid())
  eleve_id          String
  classe_id         String
  annee_scolaire_id String
  etablissement_id  String
  date              DateTime      @db.Date
  statut            String        // present | absent | retard | dispense
  justifiee         Boolean       @default(false)
  motif             String?
  heure_arrivee     String?
  cree_par          String?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  eleve          Eleve         @relation(fields: [eleve_id], references: [id])
  classe         Classe        @relation(fields: [classe_id], references: [id])
  annee_scolaire AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])
  etablissement  Etablissement @relation(fields: [etablissement_id], references: [id])

  @@unique([eleve_id, classe_id, date])
  @@index([etablissement_id, date])
  @@index([eleve_id, date])
}

model Creneau {
  id                String   @id @default(uuid())
  etablissement_id  String
  annee_scolaire_id String
  classe_id         String
  matiere_id        String
  professeur_id     String
  jour              String   // 'lundi' | 'mardi' | 'mercredi' | 'jeudi' | 'vendredi'
  heure_debut       String   // "08:00"
  heure_fin         String   // "10:00"
  salle             String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  etablissement  Etablissement @relation(fields: [etablissement_id], references: [id])
  annee_scolaire AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])
  classe         Classe        @relation(fields: [classe_id], references: [id])
  matiere        Matiere       @relation(fields: [matiere_id], references: [id])
  professeur     Professeur    @relation(fields: [professeur_id], references: [id])

  @@index([etablissement_id])
  @@index([professeur_id, annee_scolaire_id])
  @@index([classe_id, annee_scolaire_id])
}

model EvenementCalendrier {
  id               String   @id @default(uuid())
  etablissement_id String
  titre_fr         String
  titre_ar         String?
  description      String?
  date_debut       DateTime @db.Date
  date_fin         DateTime @db.Date
  type             String   // 'vacances' | 'examen' | 'evenement' | 'fermeture' | 'reunion'
  couleur          String   @default("#3B82F6")
  createur_id      String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])
  createur      Utilisateur   @relation(fields: [createur_id], references: [id])

  @@index([etablissement_id])
  @@index([etablissement_id, date_debut, date_fin])
}

model Notification {
  id               String   @id @default(uuid())
  etablissement_id String
  destinataire_id  String
  type             String   // 'absence_eleve' | 'paiement_retard' | 'note_insuffisante' | 'absence_professeur'
  titre            String
  message          String
  lu               Boolean  @default(false)
  entite_type      String?
  entite_id        String?
  created_at       DateTime @default(now())

  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])
  destinataire  Utilisateur   @relation(fields: [destinataire_id], references: [id])

  @@index([destinataire_id, lu, created_at])
  @@index([etablissement_id, created_at])
}

model Conversation {
  id               String   @id @default(uuid())
  etablissement_id String
  sujet            String
  type             String   @default("individuel") // 'individuel' | 'broadcast'
  cibles_roles     Json?    // e.g. ["professeur"] for broadcast
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  etablissement Etablissement            @relation(fields: [etablissement_id], references: [id])
  participants  ConversationParticipant[]
  messages      MessageConversation[]

  @@index([etablissement_id, updated_at])
}

model ConversationParticipant {
  id               String    @id @default(uuid())
  conversation_id  String
  utilisateur_id   String
  derniere_lecture DateTime?
  created_at       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  utilisateur  Utilisateur  @relation(fields: [utilisateur_id], references: [id])

  @@unique([conversation_id, utilisateur_id])
}

model MessageConversation {
  id              String   @id @default(uuid())
  conversation_id String
  expediteur_id   String
  corps           String
  created_at      DateTime @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  expediteur   Utilisateur  @relation(fields: [expediteur_id], references: [id])
}

model PortailParentToken {
  id               String    @id @default(uuid())
  etablissement_id String
  eleve_id         String
  token            String    @unique @default(uuid())
  actif            Boolean   @default(true)
  expires_at       DateTime?
  created_at       DateTime  @default(now())

  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])
  eleve         Eleve         @relation(fields: [eleve_id], references: [id])

  @@unique([etablissement_id, eleve_id])
  @@index([etablissement_id])
}

// ─── Phase 3.1 — Évaluations formatives ─────────────────────────────────────

model Evaluation {
  id                String   @id @default(uuid())
  etablissement_id  String
  classe_id         String
  matiere_id        String
  annee_scolaire_id String
  periode           Int
  titre             String
  type              String   // 'DS' | 'INTERRO' | 'DM' | 'EXAMEN'
  date              DateTime @db.Date
  coefficient       Decimal  @default(1)  @db.Decimal(4, 2)
  note_max          Decimal  @default(20) @db.Decimal(5, 2)
  created_by        String
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  etablissement  Etablissement    @relation(fields: [etablissement_id], references: [id])
  classe         Classe           @relation(fields: [classe_id], references: [id])
  matiere        Matiere          @relation(fields: [matiere_id], references: [id])
  annee_scolaire AnneeScolaire    @relation(fields: [annee_scolaire_id], references: [id])
  notes_eleves   NoteEvaluation[]

  @@index([etablissement_id])
  @@index([classe_id, matiere_id, periode, annee_scolaire_id])
}

model NoteEvaluation {
  id            String   @id @default(uuid())
  evaluation_id String
  eleve_id      String
  valeur        Decimal? @db.Decimal(5, 2)
  absent        Boolean  @default(false)
  commentaire   String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  evaluation Evaluation @relation(fields: [evaluation_id], references: [id], onDelete: Cascade)
  eleve      Eleve      @relation(fields: [eleve_id], references: [id])

  @@unique([evaluation_id, eleve_id])
}

// ─── Phase 3.2 — Progression élève ──────────────────────────────────────────

model ProgressionEleve {
  id                String    @id @default(uuid())
  etablissement_id  String
  eleve_id          String
  annee_scolaire_id String
  decision          String    // 'admis' | 'redoublant' | 'transfere' | 'exclu'
  decision_auto     String?
  note_directeur    String?
  validee           Boolean   @default(false)
  validee_par       String?
  validee_le        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  etablissement  Etablissement @relation(fields: [etablissement_id], references: [id])
  eleve          Eleve         @relation(fields: [eleve_id], references: [id])
  annee_scolaire AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])

  @@unique([eleve_id, annee_scolaire_id])
  @@index([etablissement_id])
}

// ─── Phase 3.3 — Activités parascolaires ────────────────────────────────────

model Activite {
  id               String   @id @default(uuid())
  etablissement_id String
  nom_fr           String
  nom_ar           String?
  description      String?
  responsable_id   String?
  capacite_max     Int?
  actif            Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  etablissement Etablissement         @relation(fields: [etablissement_id], references: [id])
  responsable   Utilisateur?          @relation("ActiviteResponsable", fields: [responsable_id], references: [id])
  inscriptions  InscriptionActivite[]
  seances       SeanceActivite[]

  @@index([etablissement_id])
  @@index([etablissement_id, actif])
}

model InscriptionActivite {
  id                String   @id @default(uuid())
  activite_id       String
  eleve_id          String
  annee_scolaire_id String
  date_inscription  DateTime @default(now())

  activite       Activite            @relation(fields: [activite_id], references: [id], onDelete: Cascade)
  eleve          Eleve               @relation(fields: [eleve_id], references: [id])
  annee_scolaire AnneeScolaire       @relation(fields: [annee_scolaire_id], references: [id])
  evaluations    EvaluationActivite[]

  @@unique([activite_id, eleve_id, annee_scolaire_id])
}

model SeanceActivite {
  id          String   @id @default(uuid())
  activite_id String
  date        DateTime @db.Date
  duree_min   Int?
  notes       String?
  created_at  DateTime @default(now())

  activite  Activite          @relation(fields: [activite_id], references: [id], onDelete: Cascade)
  presences PresenceActivite[]
}

model PresenceActivite {
  id         String   @id @default(uuid())
  seance_id  String
  eleve_id   String
  statut     String   // 'present' | 'absent' | 'retard'
  created_at DateTime @default(now())

  seance SeanceActivite @relation(fields: [seance_id], references: [id], onDelete: Cascade)
  eleve  Eleve          @relation(fields: [eleve_id], references: [id])

  @@unique([seance_id, eleve_id])
}

model EvaluationActivite {
  id                      String   @id @default(uuid())
  inscription_activite_id String
  periode                 Int?
  appreciation            String?
  note                    Decimal? @db.Decimal(5, 2)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  inscription_activite InscriptionActivite @relation(fields: [inscription_activite_id], references: [id], onDelete: Cascade)
}

// ─── Phase 5.2 — Refresh tokens ─────────────────────────────────────────────

model RefreshToken {
  id             String   @id @default(uuid())
  utilisateur_id String
  token          String   @unique @default(uuid())
  expires_at     DateTime
  revoked        Boolean  @default(false)
  created_at     DateTime @default(now())

  utilisateur Utilisateur @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([utilisateur_id])
}

// ─── Phase 4.3 — Bibliothèque scolaire ──────────────────────────────────────

model LivreStock {
  id               String   @id @default(uuid())
  etablissement_id String
  isbn             String?
  titre            String
  auteur           String?
  editeur          String?
  annee_edition    Int?
  categorie        String?
  quantite_totale  Int      @default(1)
  quantite_dispo   Int      @default(1)
  actif            Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  emprunts Emprunt[]

  @@index([etablissement_id])
}

model Emprunt {
  id                    String    @id @default(uuid())
  etablissement_id      String
  livre_id              String
  eleve_id              String
  date_emprunt          DateTime  @default(now()) @db.Date
  date_retour_prevue    DateTime  @db.Date
  date_retour_effective DateTime? @db.Date
  statut                String    @default("en_cours") // 'en_cours' | 'rendu' | 'perdu'
  cree_par              String
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  livre LivreStock @relation(fields: [livre_id], references: [id])
  eleve Eleve      @relation(fields: [eleve_id], references: [id])

  @@index([etablissement_id])
  @@index([eleve_id])
}

// ─── Documents administratifs ────────────────────────────────────────────────

enum TypeDocument {
  CERTIFICAT_SCOLARITE
  ATTESTATION_INSCRIPTION
  CONVOCATION_EXAMEN
  FICHE_TRANSFERT
  EMPLOI_DU_TEMPS_ELEVE
  RELEVE_NOTES
  CERTIFICAT_BONNE_CONDUITE
  FICHE_RENSEIGNEMENTS
  ATTESTATION_RESULTATS
  LISTE_CLASSE
  ATTESTATION_TRAVAIL
  ORDRE_MISSION
  FICHE_PAIE
  PLANNING_COURS
  CERTIFICAT_TRAVAIL_PERMANENT
  CERTIFICAT_TRAVAIL_STAGIAIRE
  ATTESTATION_SERVICE
  AUTORISATION_ABSENCE_ELEVE
  BILLET_ENTREE
  CARTE_ELEVE
  CARTE_PROFESSEUR
}

model DocumentTemplate {
  id               String       @id @default(uuid())
  etablissement_id String
  type             TypeDocument
  nom              String
  contenu_html     String
  actif            Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  etablissement     Etablissement    @relation(fields: [etablissement_id], references: [id])
  documents_generes DocumentGenere[]

  @@unique([etablissement_id, type])
}

model DocumentGenere {
  id                String       @id @default(uuid())
  etablissement_id  String
  template_id       String?
  type              TypeDocument
  destinataire_type String
  destinataire_id   String
  genere_par        String
  genere_le         DateTime     @default(now())
  parametres        Json?

  etablissement Etablissement     @relation(fields: [etablissement_id], references: [id])
  template      DocumentTemplate? @relation(fields: [template_id], references: [id])
  utilisateur   Utilisateur       @relation("DocumentsGeneres", fields: [genere_par], references: [id])

  @@index([etablissement_id, genere_le])
}

model DemandeAbsenceProfesseur {
  id               String    @id @default(uuid())
  etablissement_id String
  professeur_id    String
  date_debut       DateTime
  date_fin         DateTime
  motif            String
  type_absence     String
  statut           String    @default("EN_ATTENTE")
  commentaire      String?
  traite_par       String?
  traite_le        DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])
  professeur    Professeur    @relation(fields: [professeur_id], references: [id])
  traiteur      Utilisateur?  @relation("DemandesTraitees", fields: [traite_par], references: [id])

  @@index([etablissement_id, statut])
  @@index([professeur_id])
}
