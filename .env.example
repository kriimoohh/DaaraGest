# Backend
DATABASE_URL="postgresql://postgres:password@localhost:5432/daaragest"
JWT_SECRET="change-this-secret-in-production"
JWT_EXPIRES_IN="7d"
QR_SECRET="change-this-secret-in-production-min-32-chars"
PORT=3000
NODE_ENV=development

# Observabilité (optionnel) — laisser vide pour désactiver Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Frontend (dans frontend/.env)
VITE_API_URL=http://localhost:3000
# Observabilité frontend (optionnel)
VITE_SENTRY_DSN=
